rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin') || hasRole('warden'));
      allow write: if hasRole('admin');
    }

    // Leave Requests
    match /leave_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('warden') || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (hasRole('warden') || hasRole('admin'));
    }

    // Food Tokens
    match /food_tokens/{tokenId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('admin'));
    }

    // T-Shirt Orders
    match /tshirt_orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('warden');
    }

    // Settings (Hostel Day config)
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // Day Entries (Hostel Day Registrations)
    match /day_entries/{entryId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // Complaints
    match /complaints/{complaintId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('warden') || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (hasRole('warden') || hasRole('admin'));
    }

    // Mess Applications
    match /mess_applications/{appId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole('warden') || hasRole('admin'));
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (hasRole('warden') || hasRole('admin'));
    }
  }
}
