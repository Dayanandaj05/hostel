rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() && userDoc().exists()
          ? userDoc().data.role
          : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isWarden() {
      return userRole() == 'warden';
    }

    function isStudent() {
      return userRole() == 'student';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validTimestamp(value) {
      return value is timestamp;
    }

    function validLeaveCreate(data) {
      return data.keys().hasOnly([
          'userId',
          'startDate',
          'endDate',
          'reason',
          'status',
          'createdAt'
        ])
        && data.userId is string
        && data.userId == request.auth.uid
        && data.startDate is timestamp
        && data.endDate is timestamp
        && data.endDate >= data.startDate
        && data.reason is string
        && data.reason.size() >= 5
        && data.reason.size() <= 1000
        && data.status == 'pending'
        && validTimestamp(data.createdAt);
    }

    function validComplaintCreate(data) {
      return data.keys().hasOnly([
          'userId',
          'title',
          'description',
          'status',
          'createdAt'
        ])
        && data.userId is string
        && data.userId == request.auth.uid
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 120
        && data.description is string
        && data.description.size() >= 10
        && data.description.size() <= 3000
        && data.status == 'pending'
        && validTimestamp(data.createdAt);
    }

    function validLeaveStatusUpdate() {
      return request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'updatedAt', 'reviewedBy', 'reviewedAt'])
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.startDate == resource.data.startDate
        && request.resource.data.endDate == resource.data.endDate
        && request.resource.data.reason == resource.data.reason
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validComplaintStatusUpdate() {
      return request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'updatedAt', 'resolvedAt'])
        && request.resource.data.status in ['in_progress', 'resolved']
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.title == resource.data.title
        && request.resource.data.description == resource.data.description
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());

      // Self registration: authenticated user can create only own student profile.
      allow create: if isSignedIn() && isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'role',
          'roomId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'student';

      allow update, delete: if isAdmin();
    }

    match /leave_requests/{requestId} {
      // Students can read only their own; wardens/admins can read all.
      allow read: if isSignedIn() && (
        isAdmin() ||
        isWarden() ||
        resource.data.userId == request.auth.uid
      );

      allow create: if isSignedIn() && isStudent()
        && validLeaveCreate(request.resource.data);

      // Wardens can approve/reject leave requests; admins can do anything.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isWarden() && validLeaveStatusUpdate())
      );

      allow delete: if isAdmin();
    }

    match /complaints/{complaintId} {
      // Students can read only their own; wardens/admins can read all.
      allow read: if isSignedIn() && (
        isAdmin() ||
        isWarden() ||
        resource.data.userId == request.auth.uid
      );

      allow create: if isSignedIn() && isStudent()
        && validComplaintCreate(request.resource.data);

      // Wardens can move complaint status to in_progress/resolved; admins can do anything.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isWarden() && validComplaintStatusUpdate())
      );

      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
