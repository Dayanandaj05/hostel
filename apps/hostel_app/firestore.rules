rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStudent() { return isSignedIn() && userRole() == 'student'; }
    function isWarden()  { return isSignedIn() && userRole() == 'warden';  }
    function isAdmin()   { return isSignedIn() && userRole() == 'admin';   }
    function isStaff()   { return isWarden() || isAdmin(); }

    // Users
    match /users/{userId} {
      allow read:  if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow write: if isAdmin();
    }

    // Leave Requests
    match /leave_requests/{id} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStudent() && resource.data.userId == request.auth.uid;
    }

    // Food Tokens
    match /food_tokens/{id} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff();
    }

    // T-Shirt Orders
    match /tshirt_orders/{id} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
    }

    // Notices
    match /notices/{id} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }

    // Settings (Hostel Day config etc.)
    match /settings/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Hostel Day Registrations
    match /day_entry_registrations/{id} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
    }

    // Complaints
    match /complaints/{id} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff();
    }

    // Mess Applications
    match /mess_applications/{id} {
      allow read:   if isSignedIn() && (resource.data.studentId == request.auth.uid || isStaff());
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isStaff();
    }
  }
}
